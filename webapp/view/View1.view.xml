<mvc:View controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page title="Select Business Partner Template">
        <content>
            
            <fb:FilterBar id="filterBar" search="onSearch" showClearOnFB="true" clear="onClear" useToolbar="false">
                <fb:filterGroupItems>
                    <fb:FilterGroupItem groupName="G1" name="ID" label="Business Partner ID" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="filterID" placeholder="Enter ID..." />
                        </fb:control>
                    </fb:FilterGroupItem>
                    
                    <fb:FilterGroupItem groupName="G1" name="Category" label="Category" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="filterCategory" placeholder="Enter Category..." />
                        </fb:control>
                    </fb:FilterGroupItem>
                    
                    <fb:FilterGroupItem groupName="G1" name="Name" label="Full Name" visibleInFilterBar="true">
                        <fb:control>
                            <Input id="filterName" placeholder="Enter Name..." />
                        </fb:control>
                    </fb:FilterGroupItem>
                </fb:filterGroupItems>
            </fb:FilterBar>

            <Table id="bpTable" 
                   items="{path: '/A_BusinessPartner'}" 
                   mode="SingleSelectMaster" 
                   selectionChange="onSelectionChange"
                   growing="true"
                   growingThreshold="100"
                   growingScrollToLoad="false">
                
                <columns>
                    <Column><Text text="ID" /></Column>
                    <Column><Text text="Category" /></Column>
                    <Column><Text text="Full Name" /></Column>
                    <Column><Text text="Grouping" /></Column>
                    <Column><Text text="Created User" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onSelectionChange">
                        <cells>
                            <Text text="{BusinessPartner}" />
                            <Text text="{BusinessPartnerCategory}" />
                            <Text text="{BusinessPartnerFullName}" />
                            <Text text="{BusinessPartnerGrouping}" />
                            <Text text="{CreatedByUser}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
            
        </content>
    </Page>
</mvc:View>