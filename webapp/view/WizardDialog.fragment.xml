<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Dialog title="Create Business Partner" contentWidth="80%" contentHeight="70%" stretch="false">
        <content>
            <Wizard id="bpWizard" complete="onWizardCompleted">
                <WizardStep id="step1" title="Basic Info" validated="true">
                    <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
                        <Label text="Category" />
                        <Input value="{wizardData>/BusinessPartnerCategory}" />
                        <Label text="Full Name" />
                        <Input value="{wizardData>/BusinessPartnerFullName}" />
                        </form:SimpleForm>
                </WizardStep>
                <WizardStep id="step2" title="Review Address" validated="true">
                     </WizardStep>
            </Wizard>
        </content>
        <beginButton>
            <Button text="Submit" type="Emphasized" press="onWizardSubmit" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseDialog" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>